// Copy this file to include/secrets.h and fill in your own values.
// include/secrets.h is gitignored.
#pragma once

// --- Wi-Fi (2.4 GHz only) ---
#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

// --- Tapo P110M ---
// Give the plug a static IP / DHCP reservation on your router.
// Credentials are your Tapo (TP-Link) account login; they are only used
// locally for the KLAP handshake, nothing goes to the cloud from this device.
// NOTE: in the Tapo app enable  Me -> Third-Party Services / Compatibility.
#define TAPO_IP   "192.168.1.100"
#define TAPO_USER "you@example.com"
#define TAPO_PASS "your-tapo-password"

// --- Xiaomi LYWSDCGQ sensor ---
// Optional: pin to a specific sensor MAC (lowercase, colon separated).
// Leave empty ("") to accept the first LYWSDCGQ found; discovered Xiaomi
// devices are printed on the serial monitor so you can fill this in later.
#define SENSOR_MAC ""

// --- Network name ---
// Phone UI will be reachable at http://<APP_HOSTNAME>.local
#define APP_HOSTNAME "m5stick"
