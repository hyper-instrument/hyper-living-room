# Copy this file to .env and fill in your own values. .env is gitignored.
# Values are injected into the firmware at build time by scripts/load_env.py.

# Wi-Fi (2.4 GHz only — the ESP32-S3 has no 5 GHz radio)
WIFI_SSID=your-wifi-ssid
WIFI_PASS=your-wifi-password

# Tapo P110M smart plug.
# - Give the plug a static IP / DHCP reservation on your router.
# - Credentials are your Tapo (TP-Link) account login; they are only used
#   locally for the KLAP handshake, nothing goes to the cloud from the device.
# - In the Tapo app enable: Me -> Third-Party Services / Compatibility.
TAPO_IP=192.168.1.100
TAPO_USER=you@example.com
TAPO_PASS=your-tapo-password

# Xiaomi LYWSDCGQ sensor MAC (lowercase, colon separated).
# Leave empty to accept the first LYWSDCGQ found; discovered devices are
# printed on the serial monitor so you can pin it later.
SENSOR_MAC=

# mDNS hostname -> http://<APP_HOSTNAME>.local
APP_HOSTNAME=m5stick

# Optional WireGuard tunnel for remote access. The Stick dials out to a
# WireGuard server (e.g. a cheap VPS); your phone/laptop join the same VPN and
# reach the Stick at WG_LOCAL_IP from anywhere. Leave WG_PRIVATE_KEY empty to
# disable the tunnel entirely.
WG_PRIVATE_KEY=
WG_LOCAL_IP=10.6.0.2
WG_PEER_PUBLIC_KEY=
WG_ENDPOINT=
WG_PORT=51820
